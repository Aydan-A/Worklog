# Safe to expose in a browser bundle:
# Firebase web app config and the App Check reCAPTCHA site key are public client config.
VITE_FIREBASE_API_KEY=your-public-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_FIREBASE_APPCHECK_SITE_KEY=your-public-recaptcha-site-key

# Never put real server-side secrets in Vite env vars or commit them to this repo.
# Examples: service account JSON, Admin SDK private keys, backend API tokens, Stripe secret keys.
